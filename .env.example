# ================================================================
#  RADAR DO GREEN v2.0 — Template de Configuração
#  Arquivo: .env.example (cópia para .env e configure)
# ================================================================

# ═══════════════════════════════════════════════════════════════
#  BANCO DE DADOS (OBRIGATÓRIO)
# ═══════════════════════════════════════════════════════════════

# URL completa do banco Neon PostgreSQL
# Formato: postgresql://username:password@hostname/database?sslmode=require
DATABASE_URL=postgresql://username:password@hostname/database?sslmode=require

# ═══════════════════════════════════════════════════════════════
#  SEGURANÇA (OBRIGATÓRIO)
# ═══════════════════════════════════════════════════════════════

# Secret para sessões do Express (32+ caracteres aleatórios)
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your_session_secret_here_32_chars_minimum

# Secret para JWT (64+ caracteres aleatórios)
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here_64_chars_minimum

# ═══════════════════════════════════════════════════════════════
#  CONFIGURAÇÃO BÁSICA DO SISTEMA
# ═══════════════════════════════════════════════════════════════

# Modo de execução (development/production)
NODE_ENV=development

# Porta do servidor principal
PORT=5000

# Porta do servidor agentic
AGENTIC_PORT=5000

# ═══════════════════════════════════════════════════════════════
#  TELEGRAM (OPCIONAL - para notificações)
# ═══════════════════════════════════════════════════════════════

# Token do bot — obtenha via @BotFather → /newbot
TELEGRAM_TOKEN=your_bot_token_here

# ID do chat/grupo onde os sinais são enviados
# Obtenha via @userinfobot → /start
TELEGRAM_CHAT_ID=your_chat_id_here

# Stickers opcionais por evento.
# Ative com true e preencha os file_id dos stickers que quiser usar.
TELEGRAM_SEND_STICKERS=false
TELEGRAM_STICKER_NEW_NUMBER=
TELEGRAM_STICKER_SIGNAL=
TELEGRAM_STICKER_WIN_ENTRY=
TELEGRAM_STICKER_WIN_PROTECTION=
TELEGRAM_STICKER_PROTECTION=
TELEGRAM_STICKER_LOSS=
TELEGRAM_STICKER_TURBULENCE=
TELEGRAM_STICKER_NORMALIZED=
TELEGRAM_STICKER_MESSY_TERMINALS=
TELEGRAM_STICKER_HOT_STRATEGY=
TELEGRAM_STICKER_ANALYTICS=
TELEGRAM_STICKER_PATTERN=

# ═══════════════════════════════════════════════════════════════
#  CONFIGURAÇÕES DE ROLETA
# ═══════════════════════════════════════════════════════════════

BET_AMOUNT=10
WAIT_ROUNDS_AFTER_WIN=3
WAIT_ROUNDS_AFTER_ZERO=5

# ═══════════════════════════════════════════════════════════════
#  LOGGING E MONITORAMENTO
# ═══════════════════════════════════════════════════════════════

LOG_LEVEL=info
LOG_FILE=logs/app.log

# ═══════════════════════════════════════════════════════════════
#  VARIÁVEIS PYTHON (LEGACY - se usar sistema antigo)
# ═══════════════════════════════════════════════════════════════

DB_PATH=data/roulette.db
